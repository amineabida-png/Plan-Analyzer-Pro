# Plan Analyzer Pro — Variables d'environnement (exemple)
# Copiez ce fichier en .env et adaptez les valeurs. Ne committez JAMAIS le .env réel.

# Port d'écoute (Railway le fournit automatiquement ; en local 8000 par défaut)
PORT=8000

# --- Base de données ---
# En local : laissez vide -> SQLite (fichier plan_analyzer.db, zéro config).
# Sur Railway : ajoutez un service PostgreSQL, DATABASE_URL est injecté automatiquement.
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# --- IA Groq (gratuite) ---
# Cle gratuite sur https://console.groq.com  (Create API Key)
GROQ_API_KEY=
# Modele Groq (optionnel ; un modele Llama gratuit par defaut)
GROQ_MODEL=llama-3.3-70b-versatile
